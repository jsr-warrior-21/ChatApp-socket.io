<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Talkify | Private Messenger</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
</head>
<body class="light-theme">

    <% if (typeof isNew !== 'undefined' && isNew) { %>
        <script>
            setTimeout(() => alert("New Room Created! Share Room ID and Password with friends."), 500);
        </script>
    <% } %>

    <div class="top-logo-area">
        <div class="brand-logo">Talk<span>ify</span></div>
    </div>

    <div class="chat-container">
        <header>
            <div class="header-left">
                <div class="header-info">
                    <div class="avatar" style="background: linear-gradient(135deg, #00a884, #00d0a4) !important;">$</div>
                    <div class="user-details">
                        <h2 class="room-title">Room: <%=id%></h2>
                        <div class="status-bar">
                            <span class="online-indicator"></span>
                            <span id="user-count">... online</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="header-right">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <span id="typing" style="visibility: hidden; font-size: 0.75rem; color: var(--accent); font-style: italic;">typing...</span>
                    
                    <button onclick="clearChat()" class="clear-btn" title="Clear Chat">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                    </button>

                    <a href="/" title="Exit Room" class="clear-btn" style="text-decoration: none; display: flex; align-items: center;">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"></path></svg>
                    </a>

                    <div id="theme-toggle" onclick="toggleTheme()" class="clear-btn" style="cursor: pointer;">
                        <svg id="theme-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                    </div>
                </div>
            </div>
        </header>

        <ul id="msglist">
            <% for(let i = 0; i < chats.length; i++) { %>
                <li class="msg-bubble" data-user="<%= chats[i].user %>" ondblclick="likeMsg(this)">
                    <span class="user-name"><%= chats[i].user %></span>
                   <% if (chats[i].image) { %>
    <img src="<%= chats[i].image %>" class="chat-image" alt="Photo" onclick="openImage(this.src)" />
<% } else { %>
    <p class="content"><%= chats[i].content %></p>
<% } %>
                    <div class="msg-footer">
                        <small class="time"><%= chats[i].createdAt ? new Date(chats[i].createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : '' %></small>
                    </div>
                    <div class="heart" style="position: absolute; display: none; font-size: 2rem; top: 50%; left: 50%; transform: translate(-50%, -50%); pointer-events: none;">❤️</div>
                </li>
            <% } %>
        </ul>

        <!-- UPDATED INPUT AREA -->
        <!-- UPDATED INPUT AREA - CAMERA CORNER ME -->
<div class="input-area">
    <input id="startchat" type="hidden" data-roomId="<%=id%>">
    <input type="hidden" id="username" value="<%= userName %>">
    
    <div class="msg-input-group">
        <!-- Emoji -->
        <div class="emoji-container">
            <button class="emoji-trigger" onclick="toggleEmojiPicker()">😊</button>
            <div id="emoji-picker" class="emoji-picker">
                <span onclick="addEmoji('❤️')">❤️</span><span onclick="addEmoji('😂')">😂</span>
                <span onclick="addEmoji('🔥')">🔥</span><span onclick="addEmoji('😍')">😍</span>
                <span onclick="addEmoji('👍')">👍</span><span onclick="addEmoji('😭')">😭</span>
            </div>
        </div>
        
        <!-- Message Input + CAMERA ICON CORNER - WORKING -->
<div class="input-wrapper">
    <input type="text" id="newmsg" placeholder="Type a message..." autocomplete="off" />
    <!-- CAMERA LABEL - CLICKABLE -->
    <label for="imagefile" class="camera-icon">📷</label>
    <input type="file" id="imagefile" accept="image/*" onchange="sendImage(this)" />
</div>
        
        <!-- SEND BUTTON -->
        <button id="btn" title="Send">
            <svg viewBox="0 0 24 24" width="22" height="22">
                <path fill="white" d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"></path>
            </svg>
        </button>
    </div>
</div>


    </div>

    <!-- COPYRIGHT FOOTER -->
    <footer class="app-footer">
        <p>&copy; 2026 | <strong>Talkify</strong>.All Rights Reserved </p>
    </footer>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const msgList = document.getElementById("msglist");
        const usernameInput = document.getElementById('username');
        const inputMsg = document.getElementById("newmsg");
        const btn = document.getElementById("btn");
        const roomId = "<%=id%>";
        const userCountDisp = document.getElementById("user-count");

        // Theme Toggle
        function toggleTheme() {
            document.body.classList.toggle('dark-theme');
            const icon = document.getElementById('theme-icon');
            if(document.body.classList.contains('dark-theme')) {
                icon.innerHTML = '<circle cx="12" cy="12" r="5"></circle><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>';
            } else {
                icon.innerHTML = '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>';
            }
        }

        // Emoji & UI
        function toggleEmojiPicker() { document.getElementById('emoji-picker').classList.toggle('active'); }
        function addEmoji(e) { inputMsg.value += e; inputMsg.focus(); toggleEmojiPicker(); }
        document.addEventListener('click', (e) => { if (!e.target.closest('.emoji-container')) document.getElementById('emoji-picker').classList.remove('active'); });
        
        function clearChat() { if(confirm("Clear history for everyone?")) socket.emit('clear_all_chats', { roomId }); }
        function likeMsg(el) { 
            const h = el.querySelector('.heart'); 
            h.style.display = 'block'; 
            setTimeout(() => h.style.display = 'none', 800); 
        }
        
        function alignMessages() {
            const myName = usernameInput.value.trim();
            document.querySelectorAll('.msg-bubble').forEach(b => {
                b.classList.toggle('sent', myName && b.getAttribute('data-user') === myName);
            });
        }

  function sendImage(input) {
    const file = input.files[0];
    if (file && usernameInput.value) {
        const reader = new FileReader();
        reader.onload = (e) => {
            socket.emit('msg_send', { 
                img: e.target.result, 
                msg: "", 
                username: usernameInput.value, 
                roomId: roomId 
            });
        };
        reader.readAsDataURL(file);
        input.value = '';  // Reset
    }
}

        // Socket Events
        socket.emit('join_room', { roomId });
        socket.on('room_stats', (data) => { userCountDisp.innerText = `${data.count} online`; });
        socket.on('chat_cleared', () => { msgList.innerHTML = ""; });

        btn.onclick = () => {
            if(!inputMsg.value.trim() || !usernameInput.value) return;
            socket.emit("msg_send", { msg: inputMsg.value, username: usernameInput.value, roomId: roomId });
            inputMsg.value = "";
        };

        inputMsg.addEventListener("keypress", (e) => { if (e.key === "Enter") btn.click(); });



    socket.on("msg_rcvd", (data) => {
    const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    let li = document.createElement("li");
    li.className = 'msg-bubble fade-in';
    li.setAttribute('data-user', data.username);
    
    let inner;
    if (data.img) {
        inner = `<img src="${data.img}" class="chat-image" alt="Photo" onclick="openImage(this.src)" />`;
    } else {
        inner = `<p class="content">${data.msg}</p>`;
    }
    
    li.innerHTML = `
        <span class="user-name">${data.username}</span>
        ${inner}
        <div class="msg-footer">
            <small class="time">${time}</small>
            ${data.username === usernameInput.value ? '<span class="ticks">seen</span>' : ''}
        </div>
        <div class="heart" style="position: absolute; display: none; font-size: 2rem; top: 50%; left: 50%; transform: translate(-50%, -50%); pointer-events: none;">❤️</div>
    `;
    
    msgList.appendChild(li); 
    alignMessages(); 
    msgList.scrollTop = msgList.scrollHeight;
});

// Image click to enlarge
function openImage(src) {
    window.open(src, '_blank');
}




        inputMsg.addEventListener('input', () => socket.emit('typing', { roomId }));
        socket.on('someone_typing', () => {
            const t = document.getElementById("typing");
            t.style.visibility = 'visible';
            setTimeout(() => t.style.visibility = 'hidden', 2000);
        });

        window.onload = () => { 
            alignMessages(); 
            msgList.scrollTop = msgList.scrollHeight; 
        };
    </script>
</body>
</html>