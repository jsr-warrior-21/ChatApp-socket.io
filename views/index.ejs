<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Talkify | Private Messenger</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
</head>
<body class="light-theme">

    <div class="top-logo-area">
        <div class="brand-logo">Talk<span>ify</span></div>
    </div>

    <div class="chat-container">
        <header>
            <div class="header-left">
                <div class="header-info">
                    <div class="avatar" style="background: linear-gradient(135deg, #00a884, #00d0a4) !important;">$</div>
                    <div class="user-details">
                        <h2 class="room-title">Room: <%=id%></h2>
                        <div class="status-bar">
                            <span class="online-indicator"></span>
                            <span id="user-count">...</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="header-right">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <span id="typing">typing...</span>
                    
                    <button onclick="clearChat()" class="clear-btn" title="Clear Chat">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                    </button>

                    <a href="/" title="Exit Room" class="clear-btn" style="text-decoration: none; display: flex; align-items: center;">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                            <polyline points="16 17 21 12 16 7"></polyline>
                            <line x1="21" y1="12" x2="9" y2="12"></line>
                        </svg>
                    </a>

                    <div id="theme-toggle" onclick="toggleTheme()" class="clear-btn" style="cursor: pointer;">
                        <svg id="theme-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                    </div>
                </div>
            </div>
        </header>

        <ul id="msglist">
            <% for(let i = 0; i < chats.length; i++) { %>
                <li class="msg-bubble" data-user="<%= chats[i].user %>" ondblclick="likeMsg(this)">
                    <span class="user-name"><%= chats[i].user %></span>
                    <% if (chats[i].image) { %>
                        <img src="<%= chats[i].image %>" class="chat-image" />
                    <% } else { %>
                        <p class="content"><%= chats[i].content %></p>
                    <% } %>
                    <div class="msg-footer">
                        <small class="time"><%= chats[i].createdAt ? new Date(chats[i].createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : '10:00 AM' %></small>
                    </div>
                    <div class="heart">❤️</div>
                </li>
            <% } %>
        </ul>

        <div class="input-area">
            <input id="startchat" type="hidden" data-roomId="<%=id%>">
            
            <input type="hidden" id="username" value="<%= userName %>">
            
            <div class="msg-input-group">
                <div class="emoji-container">
                    <button class="emoji-trigger" onclick="toggleEmojiPicker()">😊</button>
                    <div id="emoji-picker" class="emoji-picker">
                        <span onclick="addEmoji('❤️')">❤️</span><span onclick="addEmoji('😂')">😂</span>
                        <span onclick="addEmoji('🔥')">🔥</span><span onclick="addEmoji('😍')">😍</span>
                        <span onclick="addEmoji('👍')">👍</span><span onclick="addEmoji('😭')">😭</span>
                    </div>
                </div>
                <input type="text" id="newmsg" placeholder="Type a message..." autocomplete="off" />
                <input type="file" id="imagefile" accept="image/*" style="display:none;" onchange="sendImage(this)" />
                <button class="upload-btn" onclick="document.getElementById('imagefile').click()" style="background:none; border:none; cursor:pointer;">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                </button>
                <button id="btn"><svg viewBox="0 0 24 24" width="24" height="24"><path fill="white" d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"></path></svg></button>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const msgList = document.getElementById("msglist");
        const usernameInput = document.getElementById('username');
        const inputMsg = document.getElementById("newmsg");
        const btn = document.getElementById("btn");
        const roomId = "<%=id%>";
        const userCountDisp = document.getElementById("user-count");

        function toggleTheme() {
            const b = document.body;
            const icon = document.getElementById('theme-icon');
            b.classList.toggle('dark-theme');
            if(b.classList.contains('dark-theme')) {
                icon.innerHTML = '<circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>';
            } else {
                icon.innerHTML = '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>';
            }
        }
        function toggleEmojiPicker() { document.getElementById('emoji-picker').classList.toggle('active'); }
        function addEmoji(e) { inputMsg.value += e; inputMsg.focus(); toggleEmojiPicker(); }
        document.addEventListener('click', (e) => { if (!e.target.closest('.emoji-container')) document.getElementById('emoji-picker').classList.remove('active'); });
        
        function clearChat() { if(confirm("Delete history?")) socket.emit('clear_all_chats', { roomId }); }
        function likeMsg(el) { const h = el.querySelector('.heart'); h.style.display = 'block'; setTimeout(() => h.style.display = 'none', 800); }
        
        function alignMessages() {
            const myName = usernameInput.value.trim();
            document.querySelectorAll('.msg-bubble').forEach(b => {
                b.classList.toggle('sent', myName && b.getAttribute('data-user') === myName);
            });
        }

        function sendImage(input) {
            const file = input.files[0];
            if (file && usernameInput.value) {
                const reader = new FileReader();
                reader.onload = (e) => socket.emit('msg_send', { img: e.target.result, msg: "", username: usernameInput.value, roomId: roomId });
                reader.readAsDataURL(file);
            }
        }

        socket.emit('join_room', { roomId });
        socket.on('room_stats', (data) => { userCountDisp.innerText = `${data.count} online`; });
        socket.on('chat_cleared', () => { msgList.innerHTML = ""; });

        btn.onclick = () => {
            if(!inputMsg.value || !usernameInput.value) return;
            socket.emit("msg_send", { msg: inputMsg.value, username: usernameInput.value, roomId: roomId });
            inputMsg.value = "";
        };

        socket.on("msg_rcvd", (data) => {
            const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            let li = document.createElement("li");
            li.className = 'msg-bubble fade-in';
            li.setAttribute('data-user', data.username);
            let inner = data.img ? `<img src="${data.img}" class="chat-image" />` : `<p class="content">${data.msg}</p>`;
            li.innerHTML = `<span class="user-name">${data.username}</span>${inner}<div class="msg-footer"><small class="time">${time}</small>${data.username === usernameInput.value ? '<span class="ticks">✓✓</span>' : ''}</div><div class="heart">❤️</div>`;
            msgList.appendChild(li); 
            alignMessages(); 
            msgList.scrollTop = msgList.scrollHeight;
        });

        inputMsg.addEventListener('input', () => socket.emit('typing', { roomId }));
        socket.on('someone_typing', () => {
            const t = document.getElementById("typing");
            t.style.visibility = 'visible';
            setTimeout(() => t.style.visibility = 'hidden', 1500);
        });

        window.onload = () => { 
            alignMessages(); 
            msgList.scrollTop = msgList.scrollHeight; 
        };
    </script>
</body>
</html>