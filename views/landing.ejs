<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Talkify | Private Messenger</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="light-theme landing-no-scroll">
    <!-- Fixed Top-Left Logo -->
    <div class="top-logo-area">
        <div class="brand-logo"><a href="/" class="brand-logo">Talk<span>ify</span></a></div>
    </div>
        
        <!-- Single Screen Hero -->
   <section class="landing-hero">
    <h1>Private. Instant. Gone.</h1>
    <p>The messenger that deletes everything when you're done.</p>
    
    <a href="/join" class="cta-button">
        Enter Chat Room →
    </a>

    <!-- NEW FEATURES -->
    <div class="features">
        <div class="feature-card">
            <h3>Create Room</h3>
            <p>Generate a room ID + password instantly.</p>
        </div>

        <div class="feature-card">
            <h3>Share Access</h3>
            <p>Invite friends securely. No signup needed.</p>
        </div>

        <div class="feature-card">
            <h3>Auto Delete</h3>
            <p>Last person leaves → everything erased forever.</p>
        </div>
    </div>
</section>

    <!-- Footer - Desktop Only -->
    <footer class="landing-footer">
        <p>&copy; 2026 Talkify | Made with ❤️ by <strong>Arvind</strong></p>
    </footer>
</body>
</html>